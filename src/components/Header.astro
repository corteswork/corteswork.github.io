---

---

<header
  class="fixed top-0 left-1/2 transform -translate-x-1/2 z-50 w-full max-w-5xl px-4 mt-4 text-white"
>
  <div
    class="bg-black rounded-full p-3 flex items-center justify-between shadow-sm border border-green-500/10"
  >
    <a href="/">
      <div class="flex items-center gap-2 flex-shrink-0">
        <div
          class="w-10 h-10 rounded-full flex items-center justify-center font-bold text-white text-xs"
          style="background-color: var(--accent-color);"
        >
          <i class="fa-solid fa-bag-shopping text-xl text-white"></i>
        </div>
        <span class="text-xl font-black text-white tracking-tighter"
          >ReMarket</span
        >
      </div>
    </a>

    <nav
      class="flex-1 flex items-center justify-center gap-4 text-xs sm:text-sm"
    >
      <a
        href="/"
        class="text-white hover:opacity-80 transition-colors font-medium"
        >Inicio</a
      >
      <a
        href="/Products"
        class="text-white hover:opacity-80 transition-colors font-medium"
        >Productos</a
      >
      <a
        href="/Help"
        class="text-white hover:opacity-80 transition-colors font-medium"
        >Ayuda</a
      >
    </nav>

    <a
      href="/Account"
      class="btn-accent px-6 py-2.5 rounded-full font-semibold text-xs sm:text-sm flex-shrink-0 ml-3 text-white flex items-center gap-2"
    >
      <i class="fa-solid fa-user"></i>
      Mi cuenta
    </a>
  </div>
</header>
