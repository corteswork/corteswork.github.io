---
---

<header class="fixed top-0 left-1/2 transform -translate-x-1/2 z-50 w-full max-w-5xl px-4 mt-4">
  <div class="bg-black rounded-full p-4 flex items-center justify-between shadow-2xl border border-green-500/20">
    <div class="flex items-center gap-2">
      <div class="w-8 h-8 rounded-full flex items-center justify-center font-bold text-white text-xs" style="background-color: var(--accent-color);">
        <lord-icon
          src="https://cdn.lordicon.com/ggirntso.json"
          trigger="hover"
          colors="primary:#ffffff"
          style="width:20px;height:20px"
        ></lord-icon>
      </div>
      <span class="font-bold text-white text-lg hidden sm:inline">SecondHand</span>
    </div>

    <nav class="hidden md:flex items-center gap-8">
      <a href="/" class="text-white hover:text-green-400 transition-colors text-sm font-medium">Inicio</a>
      <a href="#subastas" class="text-white hover:text-green-400 transition-colors text-sm font-medium">Subastas</a>
      <a href="#" class="text-white hover:text-green-400 transition-colors text-sm font-medium">Mis Ofertas</a>
      <a href="#" class="text-white hover:text-green-400 transition-colors text-sm font-medium">Ayuda</a>
    </nav>

    <div class="relative hidden md:block" id="account-menu-wrapper">
      <button
        id="account-menu-button"
        class="flex items-center gap-2 px-3 py-2 rounded-full bg-gray-900/60 hover:bg-gray-800 text-sm text-white font-medium transition-colors"
        type="button"
      >
        <div class="w-7 h-7 rounded-full bg-gray-800 flex items-center justify-center">
          <lord-icon
            src="https://cdn.lordicon.com/hrjifpbq.json"
            trigger="hover"
            colors="primary:#ffffff,secondary:#2de09f"
            style="width:18px;height:18px"
          ></lord-icon>
        </div>
        <span>Mi cuenta</span>
      </button>
      <div
        id="account-menu"
        class="absolute right-0 mt-2 w-52 rounded-2xl bg-gray-900/95 border border-gray-800 shadow-xl backdrop-blur-sm py-2 hidden"
      >
        <a
          href="/DemoProducts#my-account"
          class="flex items-center gap-2 px-4 py-2 text-sm text-gray-200 hover:bg-gray-800 transition-colors"
        >
          <span class="w-2 h-2 rounded-full" style="background-color: var(--accent-color);"></span>
          <span>Mis productos</span>
        </a>
        <a
          href="/UploadProduct"
          class="flex items-center gap-2 px-4 py-2 text-sm text-gray-200 hover:bg-gray-800 transition-colors"
        >
          <lord-icon
            src="https://cdn.lordicon.com/zrkkrrpl.json"
            trigger="hover"
            colors="primary:#2de09f,secondary:#ffffff"
            style="width:18px;height:18px"
          ></lord-icon>
          <span>Subir producto</span>
        </a>
        <div class="border-t border-gray-800 my-1"></div>
        <button class="w-full text-left px-4 py-2 text-sm text-gray-400 hover:text-gray-200 hover:bg-gray-800 transition-colors">
          Cerrar sesión
        </button>
      </div>
    </div>

    <button class="btn-accent px-4 py-2 rounded-full font-semibold text-sm md:hidden">
      Acceder
    </button>
  </div>

  <div class="md:hidden fixed bottom-4 left-4 right-4 bg-black rounded-2xl px-4 py-3 flex justify-around shadow-lg border border-green-500/20">
    <a href="/" class="text-white hover:text-green-400 transition-colors text-xs">Inicio</a>
    <a href="#subastas" class="text-white hover:text-green-400 transition-colors text-xs">Subastas</a>
    <a href="#" class="text-white hover:text-green-400 transition-colors text-xs">Ofertas</a>
    <a href="#" class="text-white hover:text-green-400 transition-colors text-xs">Ayuda</a>
  </div>
</header>

<script is:inline>
  document.addEventListener('DOMContentLoaded', () =&gt; {
    const button = document.getElementById('account-menu-button');
    const menu = document.getElementById('account-menu');

    if (!button || !menu) return;

    let isOpen = false;

    const setOpen = (open) =&gt; {
      isOpen = open;
      if (open) {
        menu.classList.remove('hidden');
      } else {
        menu.classList.add('hidden');
      }
    };

    button.addEventListener('click', (event) =&gt; {
      event.stopPropagation();
      setOpen(!isOpen);
    });

    document.addEventListener('click', () =&gt; {
      if (isOpen) {
        setOpen(false);
      }
    });
  });
</script>
