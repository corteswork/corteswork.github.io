---

---

<header
  class="fixed top-0 left-1/2 transform -translate-x-1/2 z-50 w-full max-w-5xl px-4 mt-4 text-white"
>
  <div
    class="bg-black rounded-full p-4 flex items-center justify-between shadow-2xl border border-green-500/20"
  >
    <a href="/">
      <div class="flex items-center gap-2 flex-shrink-0">
        <div
          class="w-8 h-8 rounded-full flex items-center justify-center font-bold text-white text-xs"
          style="background-color: var(--accent-color);"
        >
          <lord-icon
            src="https://cdn.lordicon.com/ggirntso.json"
            trigger="hover"
            colors="primary:#ffffff"
            style="width:20px;height:20px"></lord-icon>
        </div>
        <span class="font-bold text-white text-lg hidden sm:inline"
          >SecondHand</span
        >
      </div>
    </a>

    <nav
      class="flex-1 flex items-center justify-center gap-4 text-xs sm:text-sm"
    >
      <a
        href="/"
        class="text-white hover:opacity-80 transition-colors font-medium"
        >Inicio</a
      >
      <a
        href="/Products"
        class="text-white hover:opacity-80 transition-colors font-medium"
        >Productos</a
      >
      <a
        href="#"
        class="text-white hover:opacity-80 transition-colors font-medium"
        >Mis ofertas</a
      >
      <a
        href="#"
        class="text-white hover:opacity-80 transition-colors font-medium"
        >Ayuda</a
      >
    </nav>

    <a
      href="/Account"
      class="btn-accent px-4 py-2 rounded-full font-semibold text-xs sm:text-sm flex-shrink-0 ml-3 text-white"
    >
      Mi cuenta
    </a>
  </div>
</header>
