---
import Layout from "../../layouts/Layout.astro";
import { products } from "../../data/products.js";
import { calculateAuctionState } from "../../utils/auction.js";

export function getStaticPaths() {
    return [{ params: { username: "johndoe" } }];
}

const { username } = Astro.params;

// Mock data for the seller
const seller = {
    name: "John Doe",
    username: "johndoe",
    avatar: "JD",
    rating: 4.9,
    salesCount: 124,
    memberSince: "Marzo 2024",
    bio: "Coleccionista de tecnología vintage y entusiasta de Apple. Vendo productos en excelente estado con garantía de satisfacción.",
};

// Asumimos que los productos en el JSON pertenecen a este vendedor
const sellerProducts = products.map((p) => ({
    ...p,
    ...calculateAuctionState(p),
}));
---

<Layout title={`Perfil de ${seller.name} - ReMarket`}>
    <section class="pt-28 pb-24 bg-gray-900 min-h-screen text-white">
        <div class="max-w-7xl mx-auto px-4">
            <!-- Header del Perfil -->
            <div
                class="bg-gray-800 rounded-3xl p-8 border border-white/5 shadow-xl mb-12"
            >
                <div
                    class="flex flex-col md:flex-row gap-8 items-center md:items-start text-center md:text-left"
                >
                    <div class="relative">
                        <div
                            class="w-32 h-32 rounded-full bg-gradient-to-tr from-[#2de09f] to-emerald-400 p-1 shadow-lg"
                        >
                            <div
                                class="w-full h-full rounded-full bg-gray-900 flex items-center justify-center font-bold text-4xl text-white border-4 border-gray-800"
                            >
                                {seller.avatar}
                            </div>
                        </div>
                        <div
                            class="absolute bottom-1 right-2 w-7 h-7 bg-green-500 border-4 border-gray-800 rounded-full"
                        >
                        </div>
                    </div>

                    <div class="flex-1">
                        <div
                            class="flex flex-col md:flex-row md:items-center gap-4 mb-4"
                        >
                            <h1
                                class="text-3xl font-black text-white leading-none"
                            >
                                {seller.name}
                            </h1>
                            <span
                                class="px-4 py-1.5 bg-white/5 text-gray-300 rounded-full text-xs font-bold uppercase tracking-widest border border-white/10"
                            >
                                @{seller.username}
                            </span>
                        </div>

                        <p class="text-gray-400 text-lg max-w-2xl mb-6">
                            {seller.bio}
                        </p>

                        <div class="flex flex-wrap gap-6 text-sm font-medium">
                            <div class="flex items-center gap-2">
                                <span class="text-yellow-500 text-lg">★</span>
                                <span class="text-white">{seller.rating}</span>
                                <span class="text-gray-500">Calificación</span>
                            </div>
                            <div class="flex items-center gap-2">
                                <span class="text-white"
                                    >{seller.salesCount}</span
                                >
                                <span class="text-gray-500"
                                    >Ventas completadas</span
                                >
                            </div>
                            <div class="flex items-center gap-2 text-gray-500">
                                <i class="fa-solid fa-calendar-days text-xs"
                                ></i>
                                <span>Miembro desde {seller.memberSince}</span>
                            </div>
                        </div>
                    </div>

                    <div class="flex flex-col gap-3 w-full md:w-auto">
                        <button
                            class="btn-accent px-8 py-3 rounded-product font-bold text-sm shadow-sm flex items-center justify-center gap-2"
                        >
                            Seguir Vendedor
                        </button>
                        <button
                            class="btn-accent-outline px-8 py-3 rounded-product font-bold text-sm flex items-center justify-center gap-2 text-white border-white/20"
                        >
                            Contactar
                        </button>
                    </div>
                </div>
            </div>

            <!-- Productos Activos -->
            <div>
                <div class="flex items-center justify-between mb-8">
                    <h2 class="text-2xl font-black text-white">
                        Anuncios actuales
                    </h2>
                    <span
                        class="text-sm font-bold text-gray-500 uppercase tracking-widest"
                        >{sellerProducts.length} Activos</span
                    >
                </div>

                <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-8">
                    {
                        sellerProducts.map((product) => (
                            <a
                                href={`/product/${product.id}`}
                                class="group"
                                data-product-id={product.id}
                                data-start-price={product.startPrice}
                                data-min-price={product.minPrice}
                                data-duration={product.durationMinutes}
                            >
                                <article class="bg-gray-800 rounded-3xl overflow-hidden border border-white/5 shadow-lg transition-all hover:border-[#2de09f]/30 hover:shadow-2xl">
                                    <div class="aspect-square overflow-hidden relative">
                                        <img
                                            src={product.image}
                                            alt={product.title}
                                            class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
                                        />
                                        <div class="absolute top-4 left-4">
                                            <span class="px-3 py-1 bg-black/50 backdrop-blur-md text-white rounded-full text-[10px] font-bold uppercase tracking-widest border border-white/10">
                                                {product.category}
                                            </span>
                                        </div>
                                    </div>

                                    <div class="p-6">
                                        <h3 class="font-bold text-white mb-4 group-hover:text-[#2de09f] transition-colors line-clamp-1">
                                            {product.title}
                                        </h3>

                                        <div class="space-y-4">
                                            <div class="flex justify-between items-end">
                                                <div>
                                                    <span class="block text-[10px] text-gray-500 uppercase font-black tracking-widest mb-1">
                                                        Precio Actual
                                                    </span>
                                                    <span
                                                        class="text-2xl font-black text-white"
                                                        id={`price-${product.id}`}
                                                    >
                                                        {product.currentPrice}€
                                                    </span>
                                                </div>
                                                <div class="text-right">
                                                    <span class="block text-[10px] text-[#2de09f] uppercase font-black tracking-widest mb-1 animate-pulse">
                                                        En venta
                                                    </span>
                                                    <span
                                                        class="text-xs font-bold text-gray-400"
                                                        id={`timer-${product.id}`}
                                                    >
                                                        {
                                                            product.remainingMinutes
                                                        }{" "}
                                                        min restantes
                                                    </span>
                                                </div>
                                            </div>

                                            <div class="h-2 w-full bg-white/5 rounded-full overflow-hidden">
                                                <div
                                                    id={`progress-${product.id}`}
                                                    class="h-full bg-gradient-to-r from-[#2de09f] to-emerald-400 rounded-full transition-all duration-1000 shadow-[0_0_10px_rgba(45,224,159,0.5)]"
                                                    style={`width: ${product.progress}%`}
                                                />
                                            </div>
                                        </div>
                                    </div>
                                </article>
                            </a>
                        ))
                    }
                </div>
            </div>

            <div class="mt-16 text-center">
                <a
                    href="/Products"
                    class="inline-flex items-center gap-2 text-sm font-bold text-gray-500 hover:text-[#2de09f] transition-colors uppercase tracking-widest"
                >
                    <i class="fa-solid fa-arrow-left text-xs"></i>
                    Ver todos los anuncios
                </a>
            </div>
        </div>
    </section>

    <script is:inline>
        function updateAuctions() {
            const productCards = document.querySelectorAll("[data-product-id]");

            productCards.forEach((card) => {
                const id = card.dataset.productId;
                const startPrice = parseFloat(card.dataset.startPrice);
                const minPrice = parseFloat(card.dataset.minPrice);
                const duration = parseFloat(card.dataset.duration);

                // Lógica idéntica al backend para sincronización
                const now = new Date();
                const startTime = new Date(
                    now.getTime() - (now.getMinutes() % duration) * 60000,
                );
                const elapsedMinutes =
                    (now.getTime() - startTime.getTime()) / 60000;

                const progressPercent = Math.min(
                    100,
                    (elapsedMinutes / duration) * 100,
                );
                const totalDrop = startPrice - minPrice;
                const currentPrice = Math.max(
                    minPrice,
                    Math.floor(
                        startPrice - totalDrop * (progressPercent / 100),
                    ),
                );
                const remainingMinutes = Math.max(
                    0,
                    Math.floor(duration - elapsedMinutes),
                );

                // Actualizar UI
                const priceEl = document.getElementById(`price-${id}`);
                const timerEl = document.getElementById(`timer-${id}`);
                const progressEl = document.getElementById(`progress-${id}`);

                if (priceEl) priceEl.textContent = `${currentPrice}€`;
                if (timerEl)
                    timerEl.textContent = `${remainingMinutes} min restantes`;
                if (progressEl) progressEl.style.width = `${progressPercent}%`;
            });
        }

        // Actualizar cada segundo
        setInterval(updateAuctions, 1000);
    </script>
</Layout>
