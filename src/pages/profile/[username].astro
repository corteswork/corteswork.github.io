---
import Layout from "../../layouts/Layout.astro";

export function getStaticPaths() {
    return [{ params: { username: "johndoe" } }];
}

const { username } = Astro.params;

// Mock data for the seller
const seller = {
    name: "John Doe",
    username: "johndoe",
    avatar: "JD",
    rating: 4.9,
    salesCount: 124,
    memberSince: "Marzo 2024",
    bio: "Coleccionista de tecnología vintage y entusiasta de Apple. Vendo productos en excelente estado con garantía de satisfacción.",
    activeProducts: [
        {
            id: "1",
            title: "iPhone 13 Pro",
            category: "Electrónica",
            image: "https://images.pexels.com/photos/788946/pexels-photo-788946.jpeg?auto=compress&cs=tinysrgb&w=400",
            currentPrice: 735,
            progress: 65,
        },
        {
            id: "3",
            title: 'Monitor 27" 144Hz',
            category: "Gaming",
            image: "https://images.pexels.com/photos/5720568/pexels-photo-5720568.jpeg?auto=compress&cs=tinysrgb&w=400",
            currentPrice: 256,
            progress: 40,
        },
    ],
};
---

<Layout title={`Perfil de ${seller.name} - SecondHand`}>
    <section class="py-24 bg-gray-50 min-h-screen">
        <div class="max-w-7xl mx-auto px-4 mt-12">
            <!-- Header del Perfil -->
            <div
                class="bg-white rounded-product p-8 border border-gray-200 shadow-sm mb-12"
            >
                <div
                    class="flex flex-col md:flex-row gap-8 items-center md:items-start text-center md:text-left"
                >
                    <div class="relative">
                        <div
                            class="w-32 h-32 rounded-full bg-gradient-to-tr from-[#2de09f] to-emerald-400 p-1 shadow-sm"
                        >
                            <div
                                class="w-full h-full rounded-full bg-white flex items-center justify-center font-bold text-4xl text-gray-900 border-4 border-white"
                            >
                                {seller.avatar}
                            </div>
                        </div>
                        <div
                            class="absolute bottom-1 right-2 w-7 h-7 bg-green-500 border-4 border-white rounded-full"
                        >
                        </div>
                    </div>

                    <div class="flex-1">
                        <div
                            class="flex flex-col md:flex-row md:items-center gap-4 mb-4"
                        >
                            <h1
                                class="text-3xl font-black text-gray-900 leading-none"
                            >
                                {seller.name}
                            </h1>
                            <span
                                class="px-4 py-1.5 bg-gray-100 text-gray-600 rounded-full text-xs font-bold uppercase tracking-widest border border-gray-200"
                            >
                                @{seller.username}
                            </span>
                        </div>

                        <p class="text-gray-600 text-lg max-w-2xl mb-6">
                            {seller.bio}
                        </p>

                        <div class="flex flex-wrap gap-6 text-sm font-medium">
                            <div class="flex items-center gap-2">
                                <span class="text-yellow-500 text-lg">★</span>
                                <span class="text-gray-900"
                                    >{seller.rating}</span
                                >
                                <span class="text-gray-400">Calificación</span>
                            </div>
                            <div class="flex items-center gap-2">
                                <span class="text-gray-900"
                                    >{seller.salesCount}</span
                                >
                                <span class="text-gray-400"
                                    >Ventas completadas</span
                                >
                            </div>
                            <div class="flex items-center gap-2 text-gray-400">
                                <svg
                                    xmlns="http://www.w3.org/2000/svg"
                                    class="h-4 w-4"
                                    fill="none"
                                    viewBox="0 0 24 24"
                                    stroke="currentColor"
                                >
                                    <path
                                        stroke-linecap="round"
                                        stroke-linejoin="round"
                                        stroke-width="2"
                                        d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"
                                    ></path>
                                </svg>
                                <span>Miembro desde {seller.memberSince}</span>
                            </div>
                        </div>
                    </div>

                    <div class="flex flex-col gap-3 w-full md:w-auto">
                        <button
                            class="btn-accent px-8 py-3 rounded-product font-bold text-sm shadow-sm flex items-center justify-center gap-2"
                        >
                            Seguir Vendedor
                        </button>
                        <button
                            class="btn-accent-outline px-8 py-3 rounded-product font-bold text-sm flex items-center justify-center gap-2"
                        >
                            Contactar
                        </button>
                    </div>
                </div>
            </div>

            <!-- Productos Activos -->
            <div>
                <div class="flex items-center justify-between mb-8">
                    <h2 class="text-2xl font-black text-gray-900">
                        Anuncios actuales
                    </h2>
                    <span
                        class="text-sm font-bold text-gray-500 uppercase tracking-widest"
                        >{seller.activeProducts.length} Activos</span
                    >
                </div>

                <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-8">
                    {
                        seller.activeProducts.map((product) => (
                            <a href={`/product/${product.id}`} class="group">
                                <article class="bg-white rounded-product overflow-hidden border border-gray-200 shadow-sm transition-all hover:border-[#2de09f]/30 hover:shadow-md">
                                    <div class="aspect-square overflow-hidden relative">
                                        <img
                                            src={product.image}
                                            alt={product.title}
                                            class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
                                        />
                                        <div class="absolute top-4 left-4">
                                            <span class="px-3 py-1 bg-white/90 backdrop-blur-sm text-gray-900 rounded-product text-[10px] font-bold uppercase tracking-widest border border-gray-100">
                                                {product.category}
                                            </span>
                                        </div>
                                    </div>

                                    <div class="p-6">
                                        <h3 class="font-bold text-gray-900 mb-4 group-hover:text-[#2de09f] transition-colors line-clamp-1">
                                            {product.title}
                                        </h3>

                                        <div class="space-y-4">
                                            <div class="flex justify-between items-end">
                                                <div>
                                                    <span class="block text-[10px] text-gray-400 uppercase font-black tracking-widest mb-1">
                                                        Precio Actual
                                                    </span>
                                                    <span class="text-2xl font-black text-gray-900">
                                                        {product.currentPrice}€
                                                    </span>
                                                </div>
                                                <div class="text-right">
                                                    <span class="block text-[10px] text-[#2de09f] uppercase font-black tracking-widest mb-1 animate-pulse">
                                                        En venta
                                                    </span>
                                                    <span class="text-xs font-bold text-gray-500">
                                                        12 min restantes
                                                    </span>
                                                </div>
                                            </div>

                                            <div class="h-1.5 w-full bg-gray-100 rounded-full overflow-hidden">
                                                <div
                                                    class="h-full bg-[#2de09f] rounded-full transition-all duration-1000"
                                                    style={`width: ${product.progress}%`}
                                                />
                                            </div>
                                        </div>
                                    </div>
                                </article>
                            </a>
                        ))
                    }
                </div>
            </div>

            <div class="mt-16 text-center">
                <a
                    href="/Products"
                    class="inline-flex items-center gap-2 text-sm font-bold text-gray-400 hover:text-[#2de09f] transition-colors uppercase tracking-widest"
                >
                    <svg
                        xmlns="http://www.w3.org/2000/svg"
                        class="h-4 w-4"
                        fill="none"
                        viewBox="0 0 24 24"
                        stroke="currentColor"
                    >
                        <path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            stroke-width="2"
                            d="M10 19l-7-7m0 0l7-7m-7 7h18"></path>
                    </svg>
                    Ver todos los anuncios
                </a>
            </div>
        </div>
    </section>
</Layout>
