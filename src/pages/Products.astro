---
import Layout from "../layouts/Layout.astro";

import { products as exampleProducts } from "../data/products.js";
import { calculateAuctionState } from "../utils/auction.js";
---

<Layout title="Ofertas - ReMarket">
  <section class="pt-28 pb-20 bg-gray-900 text-white">
    <div class="max-w-7xl mx-auto px-4">
      <h1 class="text-4xl md:text-5xl font-bold mb-4">Productos destacados</h1>
      <p class="text-gray-300 mb-10 max-w-2xl">
        Explora algunos productos con precios en bajada y descubre cómo funciona
        el modelo de ReMarket.
      </p>

      <div class="space-y-6">
        <div class="flex items-center justify-between gap-4">
          <h2 class="text-2xl font-semibold">Ofertas en curso</h2>
          <a
            href="/Account"
            class="text-sm font-medium"
            style="color: var(--accent-color);"
          >
            Ir a mi cuenta
          </a>
        </div>

        <div class="grid md:grid-cols-3 gap-6">
          {
            exampleProducts.map((p) => {
              const state = calculateAuctionState(p);

              return (
                <article
                  class="product-card bg-gray-800 rounded-product p-5 border border-gray-700 hover:border-[var(--accent-color)] transition flex flex-col"
                  data-start={p.startPrice}
                  data-min={p.minPrice}
                  data-duration={p.durationMinutes}
                >
                  <div class="mb-3 aspect-square rounded-product overflow-hidden bg-gray-700">
                    <img
                      src={p.image}
                      alt={p.title}
                      class="w-full h-full object-cover"
                      loading="lazy"
                    />
                  </div>

                  <div class="flex items-start justify-between mb-2">
                    <h3 class="text-lg font-semibold">{p.title}</h3>
                    <span
                      class="text-xs px-3 py-1 rounded-product ml-2"
                      style="background-color: rgba(45, 224, 159, 0.12); color: var(--accent-color);"
                    >
                      {p.category}
                    </span>
                  </div>

                  <p class="text-gray-400 text-sm mb-3 flex-1">
                    {p.description}
                  </p>

                  <dl class="space-y-1 text-sm mb-3">
                    <div class="flex justify-between">
                      <dt class="text-gray-400">Precio inicial</dt>
                      <dd class="font-semibold">{p.startPrice} €</dd>
                    </div>
                    <div class="flex justify-between">
                      <dt class="text-gray-400">Precio mínimo</dt>
                      <dd class="font-semibold">{p.minPrice} €</dd>
                    </div>
                    <div class="flex justify-between">
                      <dt class="text-gray-400">Tiempo restante</dt>
                      <dd class="font-semibold timer-text">
                        {state.remainingMinutes} min
                      </dd>
                    </div>
                    <div class="flex justify-between">
                      <dt class="text-gray-400">Precio actual</dt>
                      <dd
                        class="font-semibold current-price-text"
                        style="color: var(--accent-color);"
                      >
                        {state.currentPrice} €
                      </dd>
                    </div>
                  </dl>

                  <div class="mb-5">
                    <div class="flex justify-between text-[11px] font-bold uppercase tracking-wider text-gray-500 mb-2">
                      <span>Inicio</span>
                      <span>Actual</span>
                      <span>Mínimo</span>
                    </div>
                    <div class="relative h-2.5 rounded-full bg-gray-700">
                      <div
                        class="progress-bar absolute inset-y-0 left-0 rounded-full"
                        style={`width: ${state.progress}%; background-color: var(--accent-color);`}
                      />
                      <div
                        class="progress-knob absolute -top-1 w-5 h-5 rounded-full border-2 border-gray-900 shadow-sm"
                        style={`left: calc(${state.progress}% - 10px); background-color: #ffffff;`}
                      />
                    </div>
                  </div>

                  <a
                    href={`/product/${p.id}`}
                    class="mt-auto w-full btn-accent py-2.5 rounded-product text-sm font-semibold flex justify-center items-center text-center"
                  >
                    Ver detalle del producto
                  </a>
                </article>
              );
            })
          }
        </div>
      </div>
    </div>
  </section>

  <script is:inline>
    function updateAuctions() {
      const cards = document.querySelectorAll(".product-card");
      const now = new Date();

      cards.forEach((card) => {
        const startPrice = parseFloat(card.dataset.start);
        const minPrice = parseFloat(card.dataset.min);
        const duration = parseFloat(card.dataset.duration);

        // Simulación determinista basada en el tiempo actual
        const startTime = new Date(
          now.getTime() -
            (now.getMinutes() % duration) * 60000 -
            now.getSeconds() * 1000,
        );
        const elapsedSeconds = (now.getTime() - startTime.getTime()) / 1000;
        const totalSeconds = duration * 60;

        const progress = Math.min(100, (elapsedSeconds / totalSeconds) * 100);
        const remainingMinutes = Math.max(
          0,
          Math.ceil((totalSeconds - elapsedSeconds) / 60),
        );
        const currentPrice = Math.max(
          minPrice,
          Math.floor(startPrice - (startPrice - minPrice) * (progress / 100)),
        );

        // Actualizar DOM
        const priceEl = card.querySelector(".current-price-text");
        const timerEl = card.querySelector(".timer-text");
        const barEl = card.querySelector(".progress-bar");
        const knobEl = card.querySelector(".progress-knob");

        if (priceEl) priceEl.textContent = `${currentPrice} €`;
        if (timerEl) timerEl.textContent = `${remainingMinutes} min`;
        if (barEl) barEl.style.width = `${progress}%`;
        if (knobEl) knobEl.style.left = `calc(${progress}% - 10px)`;
      });
    }

    // Actualizar cada segundo
    setInterval(updateAuctions, 1000);
  </script>
</Layout>
