---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Contacto - ReMarket">
    <div class="pt-28 pb-20 px-4">
        <div class="max-w-3xl mx-auto">
            <div class="text-center mb-12">
                <h1
                    class="text-4xl font-black text-gray-900 mb-4 tracking-tight"
                >
                    Contacto
                </h1>
                <p class="text-gray-600 text-lg">
                    ¿Tienes alguna duda? Estamos aquí para ayudarte.
                </p>
            </div>

            <div class="grid md:grid-cols-2 gap-8 mb-12">
                <div
                    class="bg-white p-8 rounded-lg shadow-sm border border-gray-100 flex flex-col items-center text-center"
                >
                    <div
                        class="w-16 h-16 bg-green-500/10 rounded-full flex items-center justify-center mb-4"
                    >
                        <i class="fa-solid fa-envelope text-3xl text-green-500"
                        ></i>
                    </div>
                    <h2 class="text-xl font-bold mb-2">Email</h2>
                    <p class="text-gray-500">soporte@remarket.com</p>
                </div>

                <div
                    class="bg-white p-8 rounded-3xl shadow-sm border border-gray-100 flex flex-col items-center text-center"
                >
                    <div
                        class="w-16 h-16 bg-green-500/10 rounded-full flex items-center justify-center mb-4"
                    >
                        <i
                            class="fa-solid fa-share-nodes text-3xl text-green-500"
                        ></i>
                    </div>
                    <h2 class="text-xl font-bold mb-2">Redes Sociales</h2>
                    <p class="text-gray-500">@remarket_app</p>
                </div>
            </div>

            <div
                class="bg-white rounded-lg p-8 shadow-sm border border-gray-100"
            >
                <h2 class="text-2xl font-bold mb-6">Envíanos un mensaje</h2>
                <form class="space-y-4">
                    <div class="grid md:grid-cols-2 gap-4">
                        <div>
                            <label
                                class="block text-sm font-medium text-gray-700 mb-1"
                                >Nombre</label
                            >
                            <input
                                type="text"
                                class="w-full px-4 py-3 rounded-lg border border-gray-200 focus:border-green-500 focus:outline-none transition-colors"
                                placeholder="Tu nombre"
                            />
                        </div>
                        <div>
                            <label
                                class="block text-sm font-medium text-gray-700 mb-1"
                                >Email</label
                            >
                            <input
                                type="email"
                                class="w-full px-4 py-3 rounded-lg border border-gray-200 focus:border-green-500 focus:outline-none transition-colors"
                                placeholder="tu@email.com"
                            />
                        </div>
                    </div>
                    <div>
                        <label
                            class="block text-sm font-medium text-gray-700 mb-1"
                            >Mensaje</label
                        >
                        <textarea
                            rows="4"
                            class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:border-green-500 focus:outline-none transition-colors"
                            placeholder="¿En qué podemos ayudarte?"></textarea>
                    </div>
                    <button
                        type="button"
                        class="w-full btn-accent font-bold py-4 rounded-lg transition-colors"
                    >
                        Enviar Mensaje
                    </button>
                </form>
            </div>
        </div>
    </div>
</Layout>
