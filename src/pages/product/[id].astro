---
import Layout from "../../layouts/Layout.astro";
import { products as exampleProducts } from "../../data/products.js";
import { calculateAuctionState } from "../../utils/auction.js";

export function getStaticPaths() {
    return exampleProducts.map((p) => ({
        params: { id: p.id },
        props: { product: p },
    }));
}

const { product } = Astro.props;
const state = calculateAuctionState(product);
---

<Layout title={`${product.title} - ReMarket Oferta`}>
    <section class="pt-28 pb-20 bg-gray-900 text-white min-h-screen">
        <div class="max-w-7xl mx-auto px-4 mt-8 md:mt-12">
            <div class="mb-8">
                <a
                    href="/Products"
                    class="text-sm hover:underline font-medium inline-flex items-center gap-2"
                    style="color: var(--accent-color);"
                >
                    <svg
                        xmlns="http://www.w3.org/2000/svg"
                        class="h-4 w-4"
                        fill="none"
                        viewBox="0 0 24 24"
                        stroke="currentColor"
                    >
                        <path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            stroke-width="2"
                            d="M10 19l-7-7m0 0l7-7m-7 7h18"></path>
                    </svg>
                    Volver a productos
                </a>
            </div>

            <div class="grid lg:grid-cols-12 gap-12 items-start">
                <!-- Columna de Imagen (Izquierda) - Ocupa más espacio -->
                <div class="lg:col-span-7 space-y-6">
                    <div
                        class="aspect-square rounded-product overflow-hidden bg-gray-800 border border-gray-700 shadow-lg relative group"
                    >
                        <img
                            src={product.image}
                            alt={product.title}
                            class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110"
                        />
                        <div class="absolute top-6 right-6">
                            <span
                                class="text-xs px-5 py-2.5 rounded-product font-bold uppercase tracking-widest backdrop-blur-xl border border-white/10"
                                style="background-color: rgba(0,0,0,0.7); color: var(--accent-color);"
                            >
                                {product.category}
                            </span>
                        </div>
                    </div>

                    <!-- Descripción Detallada (Debajo de la imagen en Desktop) -->
                    <div
                        class="bg-gray-800/50 rounded-product p-8 border border-gray-700/50"
                    >
                        <h2
                            class="text-xl font-bold mb-4 flex items-center gap-2 text-gray-100"
                        >
                            <svg
                                xmlns="http://www.w3.org/2000/svg"
                                class="h-5 w-5"
                                fill="none"
                                viewBox="0 0 24 24"
                                stroke="currentColor"
                            >
                                <path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    stroke-width="2"
                                    d="M4 6h16M4 12h16M4 18h7"></path>
                            </svg>
                            Descripción del producto
                        </h2>
                        <p class="text-gray-400 text-lg leading-relaxed">
                            {product.description}
                        </p>
                        <div
                            class="mt-8 pt-8 border-t border-gray-700 flex flex-wrap gap-6"
                        >
                            <div class="flex items-center gap-3">
                                <div
                                    class="w-10 h-10 rounded-full bg-gray-700 flex items-center justify-center text-[var(--accent-color)]"
                                >
                                    <svg
                                        xmlns="http://www.w3.org/2000/svg"
                                        class="h-5 w-5"
                                        fill="none"
                                        viewBox="0 0 24 24"
                                        stroke="currentColor"
                                    >
                                        <path
                                            stroke-linecap="round"
                                            stroke-linejoin="round"
                                            stroke-width="2"
                                            d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"
                                        ></path>
                                    </svg>
                                </div>
                                <span class="text-sm font-medium text-gray-300"
                                    >Autenticidad verificada</span
                                >
                            </div>
                            <div class="flex items-center gap-3">
                                <div
                                    class="w-10 h-10 rounded-full bg-gray-700 flex items-center justify-center text-[var(--accent-color)]"
                                >
                                    <svg
                                        xmlns="http://www.w3.org/2000/svg"
                                        class="h-5 w-5"
                                        fill="none"
                                        viewBox="0 0 24 24"
                                        stroke="currentColor"
                                    >
                                        <path
                                            stroke-linecap="round"
                                            stroke-linejoin="round"
                                            stroke-width="2"
                                            d="M3 10h18M7 15h1m4 0h1m-7 4h12a2 2 0 002-2V8a2 2 0 00-2-2H6a2 2 0 00-2 2v11a2 2 0 002 2z"
                                        ></path>
                                    </svg>
                                </div>
                                <span class="text-sm font-medium text-gray-300"
                                    >Pago seguro</span
                                >
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Columna de Info y Subasta (Derecha) -->
                <div class="lg:col-span-5 space-y-8">
                    <div>
                        <h1
                            class="text-4xl md:text-5xl font-black mb-4 tracking-tight leading-tight"
                        >
                            {product.title}
                        </h1>

                        <!-- Perfil del Vendedor -->
                        <div
                            class="flex items-center gap-4 p-4 bg-gray-800/30 rounded-product border border-gray-700/30 mb-8 mt-2"
                        >
                            <div class="relative">
                                <div
                                    class="w-14 h-14 rounded-full bg-gradient-to-tr from-[var(--accent-color)] to-emerald-400 p-0.5"
                                >
                                    <div
                                        class="w-full h-full rounded-full bg-gray-800 flex items-center justify-center font-bold text-lg"
                                    >
                                        JD
                                    </div>
                                </div>
                                <div
                                    class="absolute -bottom-1 -right-1 w-5 h-5 bg-green-500 border-4 border-gray-900 rounded-full"
                                >
                                </div>
                            </div>
                            <div>
                                <h4
                                    class="font-bold text-gray-100 flex items-center gap-2"
                                >
                                    John Doe
                                    <svg
                                        xmlns="http://www.w3.org/2000/svg"
                                        class="h-4 w-4 text-blue-400 filled"
                                        viewBox="0 0 20 20"
                                        fill="currentColor"
                                    >
                                        <path
                                            fill-rule="evenodd"
                                            d="M6.267 3.455a3.066 3.066 0 001.745-.723 3.066 3.066 0 013.976 0 3.066 3.066 0 001.745.723 3.066 3.066 0 012.812 2.812c.051.64.304 1.24.723 1.745a3.066 3.066 0 010 3.976 3.066 3.066 0 00-.723 1.745 3.066 3.066 0 01-2.812 2.812 3.066 3.066 0 00-1.745.723 3.066 3.066 0 01-3.976 0 3.066 3.066 0 00-1.745-.723 3.066 3.066 0 01-2.812-2.812 3.066 3.066 0 00-.723-1.745 3.066 3.066 0 010-3.976 3.066 3.066 0 00.723-1.745 3.066 3.066 0 012.812-2.812zm7.44 5.252a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z"
                                            clip-rule="evenodd"></path>
                                    </svg>
                                </h4>
                                <div
                                    class="flex items-center gap-1.5 text-xs text-gray-400 mt-0.5"
                                >
                                    <div class="flex text-yellow-500">
                                        {"★".repeat(5)}
                                    </div>
                                    <span class="font-medium">(124 ventas)</span
                                    >
                                </div>
                                <a
                                    href={`/profile/johndoe`}
                                    class="text-[var(--accent-color)] text-xs font-bold hover:underline mt-1 inline-block uppercase tracking-tighter"
                                    >Ver Perfil Vendedor</a
                                >
                            </div>
                        </div>
                    </div>

                    <div
                        id="auction-container"
                        class="bg-gray-800 rounded-product p-8 border border-gray-700 shadow-md relative overflow-hidden"
                        data-start={product.startPrice}
                        data-min={product.minPrice}
                        data-duration={product.durationMinutes}
                    >
                        <!-- Glow effect -->
                        <div
                            class="absolute -top-24 -right-24 w-48 h-48 bg-[var(--accent-color)] opacity-10 blur-[100px] pointer-events-none"
                        >
                        </div>

                        <div class="space-y-10">
                            <!-- Precio Actual -->
                            <div class="text-center">
                                <span
                                    class="text-xs text-gray-500 uppercase tracking-[0.3em] font-black block mb-4"
                                    >Precio Actual</span
                                >
                                <div class="relative inline-block">
                                    <span
                                        class="text-7xl font-black tracking-tighter text-white"
                                    >
                                        <span id="current-price-val"
                                            >{state.currentPrice}</span
                                        ><span
                                            class="text-3xl ml-2 font-bold opacity-50"
                                            >€</span
                                        >
                                    </span>
                                </div>
                            </div>

                            <!-- Barra de progreso -->
                            <div class="space-y-4">
                                <div
                                    class="flex justify-between text-[11px] text-gray-400 font-bold uppercase tracking-widest"
                                >
                                    <span>Salida: {product.startPrice}€</span>
                                    <span
                                        style="color: var(--accent-color);"
                                        class="animate-pulse"
                                        id="auction-timer"
                                        >Quedan {state.remainingMinutes} min</span
                                    >
                                    <span>Límite: {product.minPrice}€</span>
                                </div>
                                <div
                                    class="relative h-3 rounded-full bg-gray-900 border border-gray-700 shadow-inner"
                                >
                                    <div
                                        id="auction-progress-bar"
                                        class="absolute inset-y-0 left-0 rounded-full transition-all duration-1000 ease-in-out shadow-[0_0_15px_rgba(45,224,159,0.3)]"
                                        style={`width: ${state.progress}%; background-color: var(--accent-color);`}
                                    >
                                    </div>
                                    <div
                                        id="auction-progress-knob"
                                        class="absolute -top-1 w-5 h-5 rounded-full border-2 border-gray-900 shadow-lg bg-white"
                                        style={`left: calc(${state.progress}% - 10px);`}
                                    >
                                    </div>
                                </div>
                                <p
                                    class="text-[11px] text-gray-500 font-medium text-center italic"
                                >
                                    El precio baja cada minuto. ¡Compra antes de
                                    que desaparezca!
                                </p>
                            </div>

                            <!-- Acciones -->
                            <div class="space-y-4">
                                <button
                                    id="buy-btn"
                                    class="w-full btn-accent py-5 rounded-product text-xl font-black transform hover:-translate-y-0.5 transition-all active:scale-95 flex items-center justify-center gap-4"
                                >
                                    <svg
                                        xmlns="http://www.w3.org/2000/svg"
                                        class="h-6 w-6"
                                        fill="none"
                                        viewBox="0 0 24 24"
                                        stroke="currentColor"
                                    >
                                        <path
                                            stroke-linecap="round"
                                            stroke-linejoin="round"
                                            stroke-width="2"
                                            d="M13 10V3L4 14h7v7l9-11h-7z"
                                        ></path>
                                    </svg>
                                    COMPRAR AHORA
                                </button>
                                <p
                                    class="text-center text-[11px] text-gray-500 font-medium px-4"
                                >
                                    Al confirmar la compra, aceptas las
                                    condiciones de ReMarket y te comprometes a
                                    pagar el precio actual indicado.
                                </p>
                            </div>
                        </div>
                    </div>

                    <!-- Métricas o Info Extra -->
                    <div class="grid grid-cols-2 gap-4">
                        <div
                            class="bg-gray-800/40 p-4 rounded-product border border-gray-700/40 text-center"
                        >
                            <span class="block text-xl font-bold text-gray-200"
                                >24</span
                            >
                            <span
                                class="text-[10px] text-gray-500 uppercase font-bold tracking-widest"
                                >Seguidores</span
                            >
                        </div>
                        <div
                            class="bg-gray-800/40 p-4 rounded-product border border-gray-700/40 text-center"
                        >
                            <span class="block text-xl font-bold text-gray-200"
                                >142</span
                            >
                            <span
                                class="text-[10px] text-gray-500 uppercase font-bold tracking-widest"
                                >Vistas</span
                            >
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Popup de Compra -->
    <div
        id="purchase-modal"
        class="fixed inset-0 z-[100] hidden items-center justify-center px-4"
    >
        <!-- Overlay -->
        <div
            class="absolute inset-0 bg-black/60 backdrop-blur-sm"
            id="modal-overlay"
        >
        </div>

        <!-- Modal Content -->
        <div
            class="relative w-full max-w-lg bg-white rounded-product overflow-hidden shadow-2xl transform transition-all"
        >
            <div
                class="p-6 border-b border-gray-100 flex items-center justify-between bg-gray-50"
            >
                <h3
                    class="text-xl font-black text-gray-900 uppercase tracking-tighter"
                >
                    Finalizar Compra
                </h3>
                <button
                    id="close-modal"
                    class="text-gray-400 hover:text-gray-600"
                >
                    <svg
                        xmlns="http://www.w3.org/2000/svg"
                        class="h-6 w-6"
                        fill="none"
                        viewBox="0 0 24 24"
                        stroke="currentColor"
                    >
                        <path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            stroke-width="2"
                            d="M6 18L18 6M6 6l12 12"></path>
                    </svg>
                </button>
            </div>

            <div class="p-6 space-y-6">
                <!-- Desglose de Precio -->
                <div>
                    <h4
                        class="text-xs font-black text-gray-400 uppercase tracking-widest mb-3"
                    >
                        Resumen del pedido
                    </h4>
                    <div
                        class="bg-gray-50 rounded-product p-4 space-y-2 border border-gray-100"
                    >
                        <div class="flex justify-between text-sm">
                            <span class="text-gray-600">{product.title}</span>
                            <span class="font-bold text-gray-900"
                                >{product.currentPrice}€</span
                            >
                        </div>
                        <div class="flex justify-between text-sm">
                            <span class="text-gray-600">Gastos de gestión</span>
                            <span class="font-bold text-gray-900">4.99€</span>
                        </div>
                        <div
                            class="border-t border-gray-200 pt-2 mt-2 flex justify-between"
                        >
                            <span
                                class="font-black text-gray-900 uppercase text-xs"
                                >Total</span
                            >
                            <span
                                class="font-black text-[var(--accent-color)] text-xl"
                                id="total-price"
                                >{product.currentPrice + 4.99}€</span
                            >
                        </div>
                    </div>
                </div>

                <!-- Opciones de Envío -->
                <div>
                    <h4
                        class="text-xs font-black text-gray-400 uppercase tracking-widest mb-3"
                    >
                        Opciones de envío
                    </h4>
                    <div class="grid gap-3">
                        <label
                            class="relative flex items-center p-3 border border-gray-200 rounded-product cursor-pointer hover:border-[var(--accent-color)] transition group"
                        >
                            <input
                                type="radio"
                                name="shipping"
                                checked
                                class="w-4 h-4 text-[var(--accent-color)] border-gray-300 focus:ring-[var(--accent-color)]"
                            />
                            <div class="ml-3">
                                <span
                                    class="block text-sm font-bold text-gray-900"
                                    >Punto Pack (Recogida)</span
                                >
                                <span
                                    class="block text-[10px] text-gray-500 font-medium"
                                    >Llega en 3-5 días hábiles</span
                                >
                            </div>
                            <span
                                class="ml-auto text-sm font-black text-gray-900"
                                >Gratis</span
                            >
                        </label>
                        <label
                            class="relative flex items-center p-3 border border-gray-200 rounded-product cursor-pointer hover:border-[var(--accent-color)] transition group"
                        >
                            <input
                                type="radio"
                                name="shipping"
                                class="w-4 h-4 text-[var(--accent-color)] border-gray-300 focus:ring-[var(--accent-color)]"
                            />
                            <div class="ml-3">
                                <span
                                    class="block text-sm font-bold text-gray-900"
                                    >Envío a Domicilio</span
                                >
                                <span
                                    class="block text-[10px] text-gray-500 font-medium"
                                    >Entrega en mano 48/72h</span
                                >
                            </div>
                            <span
                                class="ml-auto text-sm font-black text-gray-900"
                                >+3.50€</span
                            >
                        </label>
                    </div>
                </div>

                <!-- Método de Pago -->
                <div>
                    <h4
                        class="text-xs font-black text-gray-400 uppercase tracking-widest mb-3"
                    >
                        Método de pago
                    </h4>
                    <div class="grid grid-cols-3 gap-3">
                        <button
                            class="payment-opt p-3 border border-gray-200 rounded-product hover:border-[var(--accent-color)] hover:bg-[var(--accent-color)]/5 transition flex flex-col items-center gap-2"
                            data-method="card"
                        >
                            <svg
                                xmlns="http://www.w3.org/2000/svg"
                                class="h-6 w-6 text-gray-400"
                                fill="none"
                                viewBox="0 0 24 24"
                                stroke="currentColor"
                            >
                                <path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    stroke-width="2"
                                    d="M3 10h18M7 15h1m4 0h1m-7 4h12a2 2 0 002-2V8a2 2 0 00-2-2H6a2 2 0 00-2 2v11a2 2 0 002 2z"
                                ></path>
                            </svg>
                            <span class="text-[10px] font-black uppercase"
                                >Tarjeta</span
                            >
                        </button>
                        <button
                            class="payment-opt p-3 border border-gray-200 rounded-product hover:border-[var(--accent-color)] hover:bg-[var(--accent-color)]/5 transition flex flex-col items-center gap-2"
                            data-method="paypal"
                        >
                            <svg
                                xmlns="http://www.w3.org/2000/svg"
                                class="h-6 w-6 text-gray-400"
                                fill="none"
                                viewBox="0 0 24 24"
                                stroke="currentColor"
                            >
                                <path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    stroke-width="2"
                                    d="M17 9V7a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2m2 4h10a2 2 0 002-2v-6a2 2 0 00-2-2H9a2 2 0 00-2 2v6a2 2 0 002 2zm7-5a2 2 0 11-4 0 2 2 0 014 0z"
                                ></path>
                            </svg>
                            <span class="text-[10px] font-black uppercase"
                                >PayPal</span
                            >
                        </button>
                        <button
                            class="payment-opt p-3 border border-gray-200 rounded-product hover:border-[var(--accent-color)] hover:bg-[var(--accent-color)]/5 transition flex flex-col items-center gap-2"
                            data-method="bizum"
                        >
                            <div
                                class="h-6 w-6 rounded-full bg-blue-500 flex items-center justify-center text-[8px] font-bold text-white"
                            >
                                B
                            </div>
                            <span class="text-[10px] font-black uppercase"
                                >Bizum</span
                            >
                        </button>
                    </div>
                </div>

                <button
                    class="w-full btn-accent py-4 rounded-product font-black uppercase tracking-widest text-sm transform hover:scale-[1.02] active:scale-95 transition-all"
                >
                    Confirmar Pago
                </button>
            </div>
        </div>
    </div>

    <script is:inline>
        document.addEventListener("DOMContentLoaded", () => {
            const buyBtn = document.getElementById("buy-btn");
            const modal = document.getElementById("purchase-modal");
            const overlay = document.getElementById("modal-overlay");
            const closeBtn = document.getElementById("close-modal");
            const paymentOpts = document.querySelectorAll(".payment-opt");

            const toggleModal = (show) => {
                if (show) {
                    modal.classList.remove("hidden");
                    modal.classList.add("flex");
                    document.body.style.overflow = "hidden";
                } else {
                    modal.classList.add("hidden");
                    modal.classList.remove("flex");
                    document.body.style.overflow = "";
                }
            };

            buyBtn?.addEventListener("click", () => toggleModal(true));
            overlay?.addEventListener("click", () => toggleModal(false));
            closeBtn?.addEventListener("click", () => toggleModal(false));

            paymentOpts.forEach((opt) => {
                opt.addEventListener("click", () => {
                    paymentOpts.forEach((o) =>
                        o.classList.remove(
                            "border-[var(--accent-color)]",
                            "bg-[var(--accent-color)]/5",
                        ),
                    );
                    opt.classList.add(
                        "border-[var(--accent-color)]",
                        "bg-[var(--accent-color)]/5",
                    );
                });
            });

            function updateAuction() {
                const container = document.getElementById("auction-container");
                if (!container) return;

                const startPrice = parseFloat(container.dataset.start);
                const minPrice = parseFloat(container.dataset.min);
                const duration = parseFloat(container.dataset.duration);
                const now = new Date();

                const startTime = new Date(
                    now.getTime() -
                        (now.getMinutes() % duration) * 60000 -
                        now.getSeconds() * 1000,
                );
                const elapsedSeconds =
                    (now.getTime() - startTime.getTime()) / 1000;
                const totalSeconds = duration * 60;

                const progress = Math.min(
                    100,
                    (elapsedSeconds / totalSeconds) * 100,
                );
                const remainingMinutes = Math.max(
                    0,
                    Math.ceil((totalSeconds - elapsedSeconds) / 60),
                );
                const currentPrice = Math.max(
                    minPrice,
                    Math.floor(
                        startPrice - (startPrice - minPrice) * (progress / 100),
                    ),
                );

                const priceEl = document.getElementById("current-price-val");
                const timerEl = document.getElementById("auction-timer");
                const barEl = document.getElementById("auction-progress-bar");
                const knobEl = document.getElementById("auction-progress-knob");
                const modalPriceEl = document.getElementById("total-price");

                if (priceEl) priceEl.textContent = currentPrice;
                if (timerEl)
                    timerEl.textContent = `Quedan ${remainingMinutes} min`;
                if (barEl) barEl.style.width = `${progress}%`;
                if (knobEl) knobEl.style.left = `calc(${progress}% - 10px)`;
                if (modalPriceEl)
                    modalPriceEl.textContent = `${(currentPrice + 4.99).toFixed(2)}€`;
            }

            setInterval(updateAuction, 1000);
            updateAuction();
        });
    </script>
</Layout>
