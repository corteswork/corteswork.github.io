---
import Layout from "../layouts/Layout.astro";
---

<Layout title="ReMarket - Ofertas dinámicas con precios que bajan">
  <section
    class="relative min-h-[85vh] flex items-center justify-center overflow-hidden text-white bg-gray-900 pt-24"
  >
    <!-- Animated Gradient Background -->
    <div class="absolute inset-0 z-0">
      <div
        class="absolute inset-0 opacity-40 animate-pulse-slow bg-gradient-to-br from-gray-900 via-[#1a4d3a] to-gray-900"
      >
      </div>
      <div
        class="absolute top-[-10%] left-[-10%] w-[40%] h-[40%] rounded-full bg-[var(--accent-color)] opacity-10 blur-[120px] animate-blob space-y-4"
      >
      </div>
      <div
        class="absolute bottom-[-10%] right-[-10%] w-[40%] h-[40%] rounded-full bg-emerald-500 opacity-10 blur-[120px] animate-blob animation-delay-2000"
      >
      </div>
    </div>

    <div class="relative z-10 max-w-7xl mx-auto px-4 py-32 text-center">
      <h1
        class="text-6xl md:text-8xl font-black mb-8 tracking-tighter leading-tight animate-slide-up"
      >
        Descubre el futuro de <br />
        <span
          class="text-transparent bg-clip-text bg-gradient-to-r from-[var(--accent-color)] to-emerald-300"
        >
          las compras online
        </span>
      </h1>

      <p
        class="text-xl md:text-2xl text-gray-400 mb-12 max-w-2xl mx-auto leading-relaxed animate-fade-in animation-delay-500"
      >
        En ReMarket los precios bajan cada segundo. Encuentra productos
        exclusivos y decide el momento perfecto para comprar.
      </p>

      <div
        class="flex flex-col sm:flex-row gap-5 justify-center items-center animate-fade-in animation-delay-1000"
      >
        <a
          href="/Products"
          class="btn-accent px-10 py-5 rounded-full text-lg font-black transform hover:scale-105 transition-all shadow-xl shadow-[var(--accent-color)]/20 min-w-[220px]"
        >
          Explorar Ofertas
        </a>
        <a
          href="#info"
          class="px-10 py-5 rounded-full text-lg font-bold border border-white/20 hover:bg-white/5 transition-all backdrop-blur-md min-w-[220px]"
        >
          Más Información
        </a>
      </div>
    </div>

    <style>
      @keyframes pulse-slow {
        0%,
        100% {
          opacity: 0.3;
        }
        50% {
          opacity: 0.6;
        }
      }
      .animate-pulse-slow {
        animation: pulse-slow 8s cubic-bezier(0.4, 0, 0.6, 1) infinite;
      }
      @keyframes blob {
        0%,
        100% {
          transform: translate(0, 0) scale(1);
        }
        33% {
          transform: translate(30px, -50px) scale(1.1);
        }
        66% {
          transform: translate(-20px, 20px) scale(0.9);
        }
      }
      .animate-blob {
        animation: blob 10s infinite;
      }
      .animation-delay-2000 {
        animation-delay: 2s;
      }
      .animation-delay-500 {
        animation-delay: 0.5s;
      }
      .animation-delay-1000 {
        animation-delay: 1s;
      }

      @keyframes slide-up {
        from {
          opacity: 0;
          transform: translateY(40px);
        }
        to {
          opacity: 1;
          transform: translateY(0);
        }
      }
      .animate-slide-up {
        animation: slide-up 1s cubic-bezier(0.16, 1, 0.3, 1) forwards;
      }

      @keyframes fade-in {
        from {
          opacity: 0;
        }
        to {
          opacity: 1;
        }
      }
      .animate-fade-in {
        animation: fade-in 1.2s ease-out forwards;
      }
    </style>
  </section>
  <div id="info"></div>
  <section class="py-20 bg-gray-800">
    <div class="max-w-7xl mx-auto px-4">
      <h2 class="text-4xl font-bold text-center text-white mb-16">
        ¿Cómo Funciona?
      </h2>
      <div class="grid md:grid-cols-3 gap-8">
        <div
          class="bg-gray-900 p-8 rounded-lg border border-green-500/20 hover:border-green-500/50 transition"
        >
          <div class="mb-4 flex justify-center">
            <i class="fa-solid fa-chart-line text-5xl text-green-400"></i>
          </div>
          <h3 class="font-bold text-xl text-white mb-3">Precios Dinámicos</h3>
          <p class="text-gray-400">
            Los precios comienzan altos y descienden cada segundo. Compra cuando
            consideres que es el mejor momento.
          </p>
        </div>
        <div
          class="bg-gray-900 p-8 rounded-lg border border-green-500/20 hover:border-green-500/50 transition"
        >
          <div class="mb-4 flex justify-center">
            <i class="fa-solid fa-shield-halved text-5xl text-green-400"></i>
          </div>
          <h3 class="font-bold text-xl text-white mb-3">100% Seguro</h3>
          <p class="text-gray-400">
            Transacciones protegidas, pagos verificados y garantía de comprador.
            Tu confianza es nuestra prioridad.
          </p>
        </div>
        <div
          class="bg-gray-900 p-8 rounded-lg border border-green-500/20 hover:border-green-500/50 transition"
        >
          <div class="mb-4 flex justify-center">
            <i class="fa-solid fa-star text-5xl text-green-400"></i>
          </div>
          <h3 class="font-bold text-xl text-white mb-3">Mejores Ofertas</h3>
          <p class="text-gray-400">
            Acceso a productos exclusivos con descuentos garantizados. Ahorra
            más mientras participas.
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4">
      <h2 class="text-4xl font-bold text-center text-gray-900 mb-16">
        3 Pasos Simples
      </h2>
      <div class="grid md:grid-cols-3 gap-8">
        <div class="text-center">
          <div
            class="w-16 h-16 text-white rounded-full flex items-center justify-center mx-auto mb-4 text-2xl font-bold"
            style="background-color: var(--accent-color);"
          >
            1
          </div>
          <h3 class="font-bold text-lg text-gray-900 mb-2">Regístrate</h3>
          <p class="text-gray-600">
            Crea tu cuenta en segundos y verifica tu identidad de forma segura
          </p>
        </div>
        <div class="text-center">
          <div
            class="w-16 h-16 text-white rounded-full flex items-center justify-center mx-auto mb-4 text-2xl font-bold"
            style="background-color: var(--accent-color);"
          >
            2
          </div>
          <h3 class="font-bold text-lg text-gray-900 mb-2">Explora Ofertas</h3>
          <p class="text-sm text-gray-500 leading-relaxed">
            Navega por miles de productos con precios dinámicos en tiempo real
          </p>
        </div>
        <div class="text-center">
          <div
            class="w-16 h-16 text-white rounded-full flex items-center justify-center mx-auto mb-4 text-2xl font-bold"
            style="background-color: var(--accent-color);"
          >
            3
          </div>
          <h3 class="font-bold text-lg text-gray-900 mb-2">Compra y Gana</h3>
          <p class="text-gray-600">
            Compra cuando quieras y recibe tu producto directamente en casa
          </p>
        </div>
      </div>
    </div>
  </section>

  <section
    class="py-20 bg-gradient-to-r from-green-600 to-green-500 text-white"
  >
    <div class="max-w-7xl mx-auto px-4">
      <div class="grid md:grid-cols-4 gap-8 text-center">
        <div>
          <div class="text-5xl font-bold mb-2">50K+</div>
          <p class="text-lg opacity-90">Usuarios Activos</p>
        </div>
        <div>
          <div class="text-5xl font-bold mb-2">100K+</div>
          <p class="text-lg opacity-90">Ventas Realizadas</p>
        </div>
        <div>
          <div class="text-5xl font-bold mb-2">$10M+</div>
          <p class="text-lg opacity-90">Volumen de Ventas</p>
        </div>
        <div>
          <div class="text-5xl font-bold mb-2">99.8%</div>
          <p class="text-lg opacity-90">Satisfacción</p>
        </div>
      </div>
    </div>
  </section>

  <section class="py-20 bg-gray-900 text-white">
    <div class="max-w-4xl mx-auto px-4 text-center">
      <h2 class="text-5xl font-bold mb-6">¿Listo para comenzar?</h2>
      <p class="text-xl text-gray-300 mb-10">
        Únete a miles de usuarios que ya están ahorrando con nuestras ofertas
        flash y precios en constante bajada.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a
          href="/Account"
          class="btn-accent font-bold py-4 px-10 rounded-product text-lg shadow flex items-center justify-center"
        >
          Crear mi cuenta
        </a>
        <a
          href="/Products"
          class="btn-accent-outline font-bold py-4 px-10 rounded-product text-lg flex items-center justify-center"
        >
          Ver productos destacados
        </a>
      </div>
    </div>
  </section>

  <section class="py-16 bg-white">
    <div class="max-w-2xl mx-auto px-4 text-center">
      <h3 class="text-3xl font-bold text-gray-900 mb-4">Mantente Informado</h3>
      <p class="text-gray-600 mb-6">
        Recibe notificaciones sobre nuevas gangas y ofertas exclusivas
      </p>
      <form class="flex gap-2">
        <input
          type="email"
          placeholder="tu@email.com"
          class="flex-1 px-4 py-3 bg-gray-100 rounded-lg border border-gray-300 focus:border-green-500 focus:outline-none"
        />
        <button
          class="btn-accent font-bold px-8 py-3 rounded-lg transition-colors"
        >
          Suscribir
        </button>
      </form>
    </div>
  </section>
</Layout>
