---
import Layout from "../layouts/Layout.astro";
import { products } from "../data/products.js";
import { calculateAuctionState } from "../utils/auction.js";
---

<Layout title="Mi cuenta - ReMarket">
  <section class="pt-28 pb-20 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4">
      <div
        class="mb-8 flex flex-col md:flex-row md:items-center md:justify-between gap-4"
      >
        <div class="flex items-center gap-4">
          <div
            class="w-14 h-14 rounded-full flex items-center justify-center text-white text-xl font-semibold"
            style="background-color: var(--accent-color);"
          >
            JP
          </div>
          <div>
            <h1 class="text-2xl md:text-3xl font-bold text-gray-900">
              Mi cuenta
            </h1>
            <p class="text-sm text-gray-500">
              Gestiona tus productos y datos personales.
            </p>
          </div>
        </div>
        <div class="flex gap-3">
          <a
            href="/UploadProduct"
            class="btn-accent px-4 py-2.5 rounded-lg text-sm font-semibold flex items-center gap-2"
          >
            <i class="fa-solid fa-cloud-arrow-up"></i>
            <span>Subir producto</span>
          </a>
          <a
            href="/Products"
            class="btn-accent-outline px-4 py-2.5 rounded-lg text-sm font-semibold"
          >
            Ver productos
          </a>
        </div>
      </div>

      <div class="grid lg:grid-cols-[1.2fr,0.8fr] gap-10">
        <section
          class="bg-white rounded-product shadow-sm border border-gray-200 p-6"
        >
          <h2 class="text-xl font-semibold text-gray-900 mb-1">Mis anuncios</h2>
          <p class="text-gray-500 text-sm mb-5">
            Consulta el estado de tus anuncios activos y revisa el rendimiento
            de tus ofertas dinámicas.
          </p>

          <div class="border-t border-gray-100 pt-4 space-y-4">
            {
              products.map((p, index) => {
                const state = calculateAuctionState(p);
                const isActive = index === 0 && !state.isFinished;

                return (
                  <article
                    class="account-product-card flex gap-4"
                    data-start={p.startPrice}
                    data-min={p.minPrice}
                    data-duration={p.durationMinutes}
                  >
                    <div class="w-24 h-24 rounded-product overflow-hidden bg-gray-100 flex-shrink-0">
                      <img
                        src={p.image}
                        alt={p.title}
                        class="w-full h-full object-cover"
                        loading="lazy"
                      />
                    </div>
                    <div class="flex-1">
                      <div class="flex items-start justify-between gap-3 mb-1">
                        <div>
                          <h3 class="text-sm font-semibold text-gray-900">
                            {p.title}
                          </h3>
                          <p class="text-xs text-gray-500">
                            {p.category} ·{" "}
                            <span class="status-text">
                              {isActive ? "Activa" : "Finalizada"}
                            </span>
                          </p>
                        </div>
                        <span
                          class="status-badge text-[11px] px-2 py-0.5 rounded-full"
                          style={
                            isActive
                              ? "background-color: rgba(45, 224, 159, 0.12); color: var(--accent-color);"
                              : "background-color: #f3f4f6; color: #4b5563;"
                          }
                        >
                          {isActive ? "Activa" : "Finalizada"}
                        </span>
                      </div>
                      <div class="flex justify-between text-xs text-gray-600 mb-1.5">
                        <span>
                          Inicial:{" "}
                          <span class="font-semibold text-gray-800">
                            {p.startPrice} €
                          </span>
                        </span>
                        <span>
                          Mínimo:{" "}
                          <span class="font-semibold text-gray-800">
                            {p.minPrice} €
                          </span>
                        </span>
                        <span>
                          Actual:
                          <span
                            class="font-semibold current-price-text"
                            style="color: var(--accent-color);"
                          >
                            {state.currentPrice} €
                          </span>
                        </span>
                      </div>
                      <div class="flex justify-between items-center text-[11px] text-gray-500">
                        <span>Duración: {p.durationMinutes} min</span>
                        <span class="timer-text">
                          {isActive
                            ? `Quedan: ${state.remainingMinutes} min`
                            : "Vendida"}
                        </span>
                        <span>Ofertas: {index === 0 ? "4" : "9"}</span>
                      </div>
                    </div>
                  </article>
                );
              })
            }
          </div>
        </section>

        <aside class="space-y-6">
          <div
            class="bg-white rounded-product shadow-sm border border-gray-200 p-6"
          >
            <h2 class="text-lg font-semibold text-gray-900 mb-3">
              Resumen de cuenta
            </h2>
            <dl class="space-y-2 text-sm text-gray-700">
              <div class="flex justify-between">
                <dt>Productos activos</dt>
                <dd class="font-semibold">1</dd>
              </div>
              <div class="flex justify-between">
                <dt>Ventas realizadas</dt>
                <dd class="font-semibold">12</dd>
              </div>
              <div class="flex justify-between">
                <dt>Valor vendido total</dt>
                <dd class="font-semibold">1.540 €</dd>
              </div>
            </dl>
          </div>

          <div
            class="bg-white rounded-product shadow-sm border border-gray-200 p-6"
          >
            <h2 class="text-lg font-semibold text-gray-900 mb-3">
              Acciones rápidas
            </h2>
            <div class="space-y-2 text-sm">
              <a
                href="/UploadProduct"
                class="block w-full btn-accent px-3 py-2 rounded-product text-center font-semibold"
              >
                Crear nuevo producto
              </a>
              <a
                href="/Products"
                class="block w-full btn-accent-outline px-3 py-2 rounded-product text-center font-semibold"
              >
                Ver ofertas actuales
              </a>
            </div>
          </div>
        </aside>
      </div>
    </div>
  </section>

  <script is:inline>
    function updateAccountAuctions() {
      const cards = document.querySelectorAll(".account-product-card");
      const now = new Date();

      cards.forEach((card, index) => {
        const startPrice = parseFloat(card.dataset.start);
        const minPrice = parseFloat(card.dataset.min);
        const duration = parseFloat(card.dataset.duration);

        const startTime = new Date(
          now.getTime() -
            (now.getMinutes() % duration) * 60000 -
            now.getSeconds() * 1000,
        );
        const elapsedSeconds = (now.getTime() - startTime.getTime()) / 1000;
        const totalSeconds = duration * 60;

        const progress = Math.min(100, (elapsedSeconds / totalSeconds) * 100);
        const remainingMinutes = Math.max(
          0,
          Math.ceil((totalSeconds - elapsedSeconds) / 60),
        );
        const currentPrice = Math.max(
          minPrice,
          Math.floor(startPrice - (startPrice - minPrice) * (progress / 100)),
        );

        const isFinished = remainingMinutes <= 0;
        const isActive = index === 0 && !isFinished;

        // Actualizar DOM
        const priceEl = card.querySelector(".current-price-text");
        const timerEl = card.querySelector(".timer-text");
        const statusTextEl = card.querySelector(".status-text");
        const statusBadgeEl = card.querySelector(".status-badge");

        if (priceEl) priceEl.textContent = `${currentPrice} €`;
        if (timerEl)
          timerEl.textContent = isActive
            ? `Quedan: ${remainingMinutes} min`
            : "Vendida";
        if (statusTextEl)
          statusTextEl.textContent = isActive ? "Activa" : "Finalizada";
        if (statusBadgeEl) {
          statusBadgeEl.textContent = isActive ? "Activa" : "Finalizada";
          if (isActive) {
            statusBadgeEl.style.backgroundColor = "rgba(45, 224, 159, 0.12)";
            statusBadgeEl.style.color = "var(--accent-color)";
          } else {
            statusBadgeEl.style.backgroundColor = "#f3f4f6";
            statusBadgeEl.style.color = "#4b5563";
          }
        }
      });
    }

    setInterval(updateAccountAuctions, 1000);
  </script>
</Layout>
