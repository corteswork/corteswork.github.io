---
import Header from "../components/Header.astro";
import "../styles/tailwind.css";
import "../styles/global.css";

interface Props {
  title: string;
  description?: string;
}

const { title, description = "Plataforma de subastas holandesas" } =
  Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <script src="https://cdn.lordicon.com/lordicon.js"></script>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap"
      rel="stylesheet"
    />
    <link rel="preconnect" href="https://fonts.googleapis.com" /><link
      rel="preconnect"
      href="https://fonts.gstatic.com"
      crossorigin
    /><link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap"
      rel="stylesheet"
    /><style is:global>
      :root {
        --accent-color: #2de09f;
      }
      body {
        font-family:
          "Inter",
          -apple-system,
          BlinkMacSystemFont,
          "Segoe UI",
          Roboto,
          Helvetica,
          Arial,
          sans-serif;
      }
      /* Forzar redondeados bajos globalmente o por utilidad */
      .rounded-apple {
        border-radius: 6px;
      }
    </style></head
  >
</html>
<body class="bg-gray-50 min-h-screen flex flex-col">
  <Header />
  <main class="flex-1">
    <slot />
  </main>
  <footer class="bg-gray-900 text-white mt-12 py-12 border-t border-gray-800">
    <div class="max-w-7xl mx-auto px-4">
      <div class="grid md:grid-cols-4 gap-8 mb-8">
        <div>
          <h3 class="text-lg font-bold mb-4 flex items-center gap-2">
            <span class="inline-flex items-center justify-center">
              <lord-icon
                src="https://cdn.lordicon.com/ggirntso.json"
                trigger="hover"
                colors="primary:#2de09f,secondary:#2de09f"
                style="width:32px;height:32px"></lord-icon>
            </span>
            SecondHand
          </h3>
          <p class="text-gray-400 text-sm">
            La plataforma de subastas holandesas donde los precios bajan cada
            segundo.
          </p>
        </div>

        <div>
          <h4
            class="text-sm font-bold mb-4"
            style="color: var(--accent-color);"
          >
            Comprar
          </h4>
          <ul class="space-y-2 text-gray-400 text-sm">
            <li>
              <a href="#" class="hover:text-green-400 transition"
                >Explorar Subastas</a
              >
            </li>
            <li>
              <a href="#" class="hover:text-green-400 transition">Mis Ofertas</a
              >
            </li>
            <li>
              <a href="#" class="hover:text-green-400 transition">Favoritos</a>
            </li>
            <li>
              <a href="#" class="hover:text-green-400 transition">Historial</a>
            </li>
          </ul>
        </div>

        <div>
          <h4
            class="text-sm font-bold mb-4"
            style="color: var(--accent-color);"
          >
            Vender
          </h4>
          <ul class="space-y-2 text-gray-400 text-sm">
            <li>
              <a href="#" class="hover:text-green-400 transition"
                >Crear Subasta</a
              >
            </li>
            <li>
              <a href="#" class="hover:text-green-400 transition"
                >Mis Productos</a
              >
            </li>
            <li>
              <a href="#" class="hover:text-green-400 transition">Ventas</a>
            </li>
            <li>
              <a href="#" class="hover:text-green-400 transition"
                >Configuración</a
              >
            </li>
          </ul>
        </div>

        <!-- Soporte -->
        <div>
          <h4
            class="text-sm font-bold mb-4"
            style="color: var(--accent-color);"
          >
            Soporte
          </h4>
          <ul class="space-y-2 text-gray-400 text-sm">
            <li>
              <a href="#" class="hover:text-green-400 transition"
                >Centro de Ayuda</a
              >
            </li>
            <li>
              <a href="#" class="hover:text-green-400 transition">Contacto</a>
            </li>
            <li>
              <a
                href="/politica-privacidad"
                class="hover:text-green-400 transition">Privacidad</a
              >
            </li>
            <li>
              <a href="#" class="hover:text-green-400 transition">Términos</a>
            </li>
          </ul>
        </div>
      </div>

      <!-- Divider -->
      <div class="border-t border-gray-800 pt-8 mt-8">
        <!-- Social Links -->
        <div class="flex justify-center gap-6 mb-6">
          <a
            href="#"
            class="text-gray-400 hover:text-green-400 transition"
            aria-label="Facebook"
          >
            <lord-icon
              src="https://cdn.lordicon.com/kthelypq.json"
              trigger="hover"
              colors="primary:#9ca3af,secondary:#2de09f"
              style="width:30px;height:30px"></lord-icon>
          </a>
          <a
            href="#"
            class="text-gray-400 hover:text-green-400 transition"
            aria-label="X"
          >
            <lord-icon
              src="https://cdn.lordicon.com/ulnswmkk.json"
              trigger="hover"
              colors="primary:#9ca3af,secondary:#2de09f"
              style="width:30px;height:30px"></lord-icon>
          </a>
          <a
            href="#"
            class="text-gray-400 hover:text-green-400 transition"
            aria-label="LinkedIn"
          >
            <lord-icon
              src="https://cdn.lordicon.com/oqdmuxru.json"
              trigger="hover"
              colors="primary:#9ca3af,secondary:#2de09f"
              style="width:30px;height:30px"></lord-icon>
          </a>
          <a
            href="#"
            class="text-gray-400 hover:text-green-400 transition"
            aria-label="YouTube"
          >
            <lord-icon
              src="https://cdn.lordicon.com/abfverha.json"
              trigger="hover"
              colors="primary:#9ca3af,secondary:#2de09f"
              style="width:30px;height:30px"></lord-icon>
          </a>
        </div>

        <!-- Cookie banner -->
        <div id="cookie-banner" class="fixed inset-x-0 bottom-0 z-50 hidden">
          <div class="max-w-7xl mx-auto px-4 pb-4">
            <div
              class="bg-gray-900 text-white rounded-md p-4 shadow-md border border-gray-700 flex flex-col md:flex-row md:items-center md:justify-between gap-4"
            >
              <div class="text-sm text-gray-200">
                <p class="font-semibold mb-1">Usamos cookies</p>
                <p class="text-gray-400">
                  Utilizamos cookies propias y de terceros para analizar el
                  tráfico y mejorar tu experiencia. Puedes obtener más
                  información en nuestra
                  <a
                    href="/politica-privacidad"
                    class="underline"
                    style="color: var(--accent-color);"
                    >Política de Privacidad</a
                  >.
                </p>
              </div>
              <div class="flex gap-3 justify-end">
                <button
                  data-cookie-accept
                  class="btn-accent px-4 py-2 rounded-product text-sm font-semibold"
                >
                  Aceptar
                </button>
              </div>
            </div>
          </div>
        </div>

        <!-- Copyright -->
        <div class="text-center text-gray-500 text-sm">
          <p>&copy; 2026 SecondHand. Todos los derechos reservados.</p>
          <p class="mt-2">
            Plataforma de subastas holandesas con ofertas dinámicas
          </p>
        </div>
      </div>
    </div>
  </footer>
  <script is:inline>
    document.addEventListener("DOMContentLoaded", () => {
      const banner = document.getElementById("cookie-banner");
      if (!banner) return;

      const accepted = window.localStorage.getItem("cookie_consent");
      if (!accepted) {
        banner.classList.remove("hidden");
      }

      const acceptBtn = banner.querySelector("[data-cookie-accept]");
      if (acceptBtn) {
        acceptBtn.addEventListener("click", () => {
          window.localStorage.setItem("cookie_consent", "true");
          banner.classList.add("hidden");
        });
      }
    });
  </script>
</body>
